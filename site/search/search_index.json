{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9996\u9875","text":"<p>CHINESE PATTERN LIBRARY</p> \u4e2d\u56fd\u56fe\u6848\u98ce\u683c\u6587\u6863\u7ad9 <p>\u4ee5\u201c\u7c73\u8272\u7eb8\u611f\u80cc\u666f + \u6731\u7ea2\u5f3a\u8c03 + \u6df1\u58a8\u6587\u5b57\u201d\u4e3a\u89c6\u89c9\u57fa\u8c03\uff0c\u6574\u7406\u56fe\u6848\u8d44\u6599\u3001\u5206\u7c7b\u7d22\u5f15\u4e0e\u8bbe\u8ba1\u8bf4\u660e\u3002</p> \u5206\u7c7b\u68c0\u7d22\u603b\u89c8 \u6309\u65f6\u4ee3 \u6309\u5730\u57df \u6309\u7c7b\u522b \u6309\u5de5\u827a \u7eb9\u6837\u80cc\u666f\u56fe\u5c42 <p>\u80cc\u666f\u56fe\u4f7f\u7528\u8fde\u7eed\u56de\u7eb9\u4e0e\u51e0\u4f55\u7ebf\u6846\u53e0\u52a0\uff0c\u6a21\u62df\u4f20\u7edf\u7eb9\u6837\u5728\u7eb8\u672c\u4e0a\u7684\u9648\u5217\u8d28\u611f\u3002</p> \u65f6\u4ee3 <p>\u77f3\u5668\u65f6\u4ee3 / \u590f\u5546\u5468 / \u79e6\u6c49 / \u968b\u5510 / \u5b8b\u5143\u660e\u6e05 / \u8fd1\u73b0\u4ee3</p> \u5730\u57df <p>\u4e2d\u539f / \u6c5f\u5357 / \u897f\u5357\u5c11\u6570\u6c11\u65cf / \u6d77\u4e0a\u4e1d\u8def / \u5317\u65b9\u8349\u539f</p> \u7c7b\u522b <p>\u51e0\u4f55\u7eb9 / \u52a8\u7269\u7eb9 / \u690d\u7269\u7eb9 / \u5409\u7965\u7eb9 / \u5b97\u6559\u7eb9</p> \u8f7d\u4f53\u4e0e\u5de5\u827a <p>\u7ec7\u7ee3 / \u9676\u74f7 / \u6f06\u5668 / \u6728\u523b / \u5efa\u7b51\u88c5\u9970 / \u91d1\u77f3\u5668</p>"},{"location":"#_1","title":"\u63a8\u8350\u673a\u6784","text":"<ul> <li>\u4e2d\u592e\u7f8e\u672f\u5b66\u9662</li> <li>\u4e2d\u56fd\u56fd\u5bb6\u535a\u7269\u9986</li> <li>\u4e2d\u56fd\u7f8e\u672f\u9986</li> <li>\u6e05\u534e\u5927\u5b66\u7f8e\u672f\u5b66\u9662</li> <li>\u5c71\u4e1c\u535a\u7269\u9986</li> </ul> \u592e<p>\u4e2d\u592e\u7f8e\u672f\u5b66\u9662</p> \u56fd<p>\u4e2d\u56fd\u56fd\u5bb6\u535a\u7269\u9986</p> \u7f8e<p>\u4e2d\u56fd\u7f8e\u672f\u9986</p> \u6e05<p>\u6e05\u534e\u5927\u5b66\u7f8e\u672f\u5b66\u9662</p> \u9c81<p>\u5c71\u4e1c\u535a\u7269\u9986</p>"},{"location":"#_2","title":"\u4f7f\u7528\u8bf4\u660e","text":"<p>\u7ad9\u70b9\u5b9a\u4f4d</p> <pre><code>\u672c\u7ad9\u7528\u4e8e\u6574\u7406\u56fe\u6848\u8d44\u6599\u4e0e\u98ce\u683c\u5316\u53c2\u8003\uff0c\u4e0d\u4f5c\u4e3a\u539f\u4f5c\u7248\u6743\u5f52\u5c5e\u5224\u65ad\u4f9d\u636e\u3002\n</code></pre> <p>\u68c0\u7d22\u5efa\u8bae</p> <pre><code>\u5efa\u8bae\u5148\u6309\u201c\u65f6\u4ee3\u201d\u4e0e\u201c\u7c7b\u522b\u201d\u7b5b\u9009\uff0c\u518d\u6309\u201c\u5730\u57df\u201d\u548c\u201c\u5de5\u827a\u201d\u7ec6\u5316\uff0c\u4ee5\u63d0\u5347\u8d44\u6599\u547d\u4e2d\u7387\u3002\n</code></pre>"},{"location":"about/","title":"\u5173\u4e8e","text":"<p>\u672c\u7ad9\u53c2\u8003\u4e2d\u56fd\u56fe\u6848\u8d44\u6e90\u7c7b\u7f51\u7ad9\u7684\u89c6\u89c9\u8bed\u8a00\uff0c\u91c7\u7528\u7eb8\u611f\u5e95\u8272\u3001\u6731\u7ea2\u5f3a\u8c03\u548c\u5361\u7247\u5316\u68c0\u7d22\u5e03\u5c40\uff0c\u670d\u52a1\u4e8e\u56fe\u6848\u8d44\u6599\u6574\u7406\u4e0e\u8bbe\u8ba1\u7814\u7a76\u3002</p>"},{"location":"about/#_2","title":"\u5185\u5bb9\u8303\u56f4","text":"<ul> <li>\u56fe\u6848\u5206\u7c7b\u68c0\u7d22\u4e0e\u793a\u4f8b\u8bf4\u660e</li> <li>\u673a\u6784\u4e0e\u9986\u85cf\u6765\u6e90\u68b3\u7406</li> <li>\u521b\u4f5c\u4e0e\u7814\u7a76\u4e2d\u7684\u6837\u5f0f\u53c2\u8003</li> </ul>"},{"location":"about/#_3","title":"\u7248\u6743\u63d0\u793a","text":"<p>\u672c\u7ad9\u4ec5\u7528\u4e8e\u5b66\u4e60\u4e0e\u7814\u7a76\u5c55\u793a\uff0c\u539f\u59cb\u7d20\u6750\u7248\u6743\u5f52\u5c5e\u5176\u6743\u5229\u65b9\u3002</p>"},{"location":"institutions/","title":"\u673a\u6784\u8d44\u6e90\u673a\u6784\u4e0e\u9986\u85cf\u6765\u6e90","text":"<p>PARTNER INSTITUTIONS</p> <p>\u4ee5\u4e0b\u673a\u6784\u4e3a\u56fe\u6848\u7814\u7a76\u4e0e\u89c6\u89c9\u8d44\u6599\u7684\u91cd\u8981\u6765\u6e90\uff0c\u53ef\u4f5c\u4e3a\u8fdb\u4e00\u6b65\u68c0\u7d22\u5165\u53e3\u3002</p> \u592e<p>\u4e2d\u592e\u7f8e\u672f\u5b66\u9662</p> \u56fd<p>\u4e2d\u56fd\u56fd\u5bb6\u535a\u7269\u9986</p> \u7f8e<p>\u4e2d\u56fd\u7f8e\u672f\u9986</p> \u6e05<p>\u6e05\u534e\u5927\u5b66\u7f8e\u672f\u5b66\u9662</p> \u9c81<p>\u5c71\u4e1c\u535a\u7269\u9986</p> \u5de5<p>\u5c71\u4e1c\u5de5\u827a\u7f8e\u672f\u5b66\u9662</p>"},{"location":"classification/","title":"\u5206\u7c7b\u68c0\u7d22\u5206\u7c7b\u68c0\u7d22\u603b\u89c8","text":"<p>ADVANCED FILTER</p> <p>\u901a\u8fc7\u65f6\u4ee3\u3001\u5730\u57df\u3001\u7c7b\u522b\u548c\u5de5\u827a\u8fdb\u884c\u4ea4\u53c9\u7b5b\u9009\uff0c\u5feb\u901f\u5b9a\u4f4d\u56fe\u6848\u53c2\u8003\u3002</p> \u6309\u65f6\u4ee3 \u6309\u5730\u57df \u6309\u7c7b\u522b \u6309\u5de5\u827a \u5148\u9009\u65f6\u4ee3 <p>\u786e\u5b9a\u5386\u53f2\u8bed\u5883\uff0c\u907f\u514d\u98ce\u683c\u6df7\u7528\u3002</p> \u518d\u9009\u5730\u57df <p>\u8865\u5145\u5730\u65b9\u5de5\u827a\u4e0e\u5ba1\u7f8e\u5dee\u5f02\u3002</p> \u53e0\u52a0\u7c7b\u522b <p>\u96c6\u4e2d\u5728\u7eb9\u6837\u8bed\u4e49\u4e0e\u6784\u56fe\u65b9\u5f0f\u3002</p> \u6536\u655b\u5de5\u827a <p>\u6839\u636e\u6750\u6599\u4e0e\u5236\u4f5c\u65b9\u5f0f\u9501\u5b9a\u53ef\u843d\u5730\u53c2\u8003\u3002</p>"},{"location":"classification/category/","title":"\u6309\u7c7b\u522b\u68c0\u7d22","text":"\u68c0\u7d22\u603b\u89c8 \u6309\u65f6\u4ee3 \u6309\u5730\u57df \u6309\u5de5\u827a \u51e0\u4f55\u7eb9<p>\u56de\u7eb9\u3001\u96f7\u7eb9\u3001\u4e91\u96f7\u7eb9\u4e0e\u8fde\u7eed\u8fb9\u9970\u3002</p> \u52a8\u7269\u7eb9<p>\u9f99\u51e4\u3001\u745e\u517d\u3001\u9c7c\u9e1f\u4e0e\u6606\u866b\u7eb9\u3002</p> \u690d\u7269\u7eb9<p>\u7f20\u679d\u3001\u6298\u679d\u3001\u83b2\u82b1\u4e0e\u7261\u4e39\u3002</p> \u5409\u7965\u7eb9<p>\u798f\u7984\u5bff\u559c\u3001\u535a\u53e4\u4e0e\u5668\u7269\u5bd3\u610f\u7eb9\u3002</p>"},{"location":"classification/craft/","title":"\u6309\u5de5\u827a\u68c0\u7d22","text":"\u68c0\u7d22\u603b\u89c8 \u6309\u65f6\u4ee3 \u6309\u5730\u57df \u6309\u7c7b\u522b \u7ec7\u7ee3<p>\u7eac\u9526\u3001\u5986\u82b1\u3001\u523a\u7ee3\u4e0e\u6311\u82b1\u3002</p> \u9676\u74f7<p>\u9752\u82b1\u3001\u6597\u5f69\u3001\u523b\u82b1\u4e0e\u5370\u82b1\u3002</p> \u6f06\u5668\u6728\u4f5c<p>\u96d5\u6f06\u3001\u63cf\u91d1\u4e0e\u6728\u523b\u88c5\u9970\u3002</p> \u5efa\u7b51\u91d1\u77f3<p>\u7816\u96d5\u3001\u77f3\u523b\u3001\u85fb\u4e95\u4e0e\u74e6\u5f53\u3002</p>"},{"location":"classification/era/","title":"\u6309\u65f6\u4ee3\u68c0\u7d22","text":"\u68c0\u7d22\u603b\u89c8 \u6309\u5730\u57df \u6309\u7c7b\u522b \u6309\u5de5\u827a \u5148\u79e6<p>\u77f3\u5668\u65f6\u4ee3\u3001\u590f\u5546\u5468\u3001\u79e6\u6c49\u3002</p> \u4e2d\u53e4<p>\u9b4f\u664b\u5357\u5317\u671d\u3001\u968b\u5510\u3001\u4e94\u4ee3\u3002</p> \u8fd1\u4e16<p>\u5b8b\u8fbd\u91d1\u3001\u5143\u660e\u6e05\u3002</p> \u8fd1\u73b0\u4ee3<p>\u6c11\u56fd\u5230\u5f53\u4ee3\u56fe\u5f62\u8f6c\u8bd1\u3002</p>"},{"location":"classification/region/","title":"\u6309\u5730\u57df\u68c0\u7d22","text":"\u68c0\u7d22\u603b\u89c8 \u6309\u65f6\u4ee3 \u6309\u7c7b\u522b \u6309\u5de5\u827a \u4e2d\u539f<p>\u793c\u5236\u7eb9\u6837\u3001\u9752\u94dc\u7eb9\u7cfb\u7edf\u3002</p> \u6c5f\u5357<p>\u4e1d\u7ec7\u4e0e\u56ed\u6797\u88c5\u9970\u56fe\u6848\u3002</p> \u897f\u5357<p>\u5c11\u6570\u6c11\u65cf\u7ec7\u7ee3\u4e0e\u94f6\u9970\u7eb9\u6837\u3002</p> \u5317\u65b9<p>\u8349\u539f\u7eb9\u6837\u4e0e\u6e38\u7267\u5668\u7269\u88c5\u9970\u3002</p>"}]}